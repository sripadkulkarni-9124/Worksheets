# ─── Required ──────────────────────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# ─── Optional ──────────────────────────────────────────────────

# Comma-separated allowed origins for CORS. Add production domain here.
# CORS_ORIGINS=http://localhost:5173,https://ved.example.com

# Max request body size in MB (default 15).
# MAX_BODY_MB=15

# Log level: DEBUG, INFO, WARNING, ERROR (default INFO).
# LOG_LEVEL=INFO
